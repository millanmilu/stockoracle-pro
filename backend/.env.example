# Copy this file to backend/.env on EC2 and set the real values there.
# Never commit backend/.env or real credentials.
ENV=production
PORT=8000
AWS_REGION=us-east-1

ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=
SECRET_KEY=

# Comma-separated browser origins permitted to call this API.
# Example: https://main.xxxxxx.amplifyapp.com,https://your-domain.com
ALLOWED_ORIGINS=
